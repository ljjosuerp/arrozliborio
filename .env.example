# ── App ──────────────────────────────────────────────────────────────
APP_NAME="Arrocera Liborio"
APP_ENV=local                 # En producción: production
APP_KEY=                      # Generar con: php artisan key:generate
APP_DEBUG=true                # En producción: false  (¡importante!)
APP_URL=http://localhost      # En producción: https://tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # En producción: error

# ── Base de datos ────────────────────────────────────────────────────
# SQLite (simple, por defecto). Para MySQL: cambiar DB_CONNECTION=mysql y completar abajo.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=arrozliborio
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Almacenamiento de archivos subidos (fotos del admin, CV).
# local = disco del servidor.  s3 = bucket S3 (recomendado en hosts efímeros).
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Correo ───────────────────────────────────────────────────────────
# log = NO envía (solo desarrollo). En producción usar SMTP real (smtp).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@arrozliborio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── S3 (solo si FILESYSTEM_DISK=s3) ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
